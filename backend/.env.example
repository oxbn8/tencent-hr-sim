# 腾讯混元 · 复制为 backend/.env 后填入密钥（不要提交到 Git）

# ---------- 对话（混元 OpenAI 兼容）----------
LLM_PROVIDER=hunyuan
HUNYUAN_API_KEY=your-hunyuan-api-key
# 或使用统一变量：LLM_API_KEY=your-key

LLM_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
LLM_MODEL=hunyuan-turbos-latest
# 可选模型：hunyuan-turbo / hunyuan-turbos-latest / hunyuan-pro

# 若使用 TokenHub 统一接入对话：
# LLM_BASE_URL=https://tokenhub.tencentmaas.com/v1
# LLM_MODEL=hy3-preview

HUNYUAN_ENABLE_ENHANCEMENT=false
LLM_MAX_TOKENS=1024
LLM_CHAT_TIMEOUT=45
IMAGE_GEN_TIMEOUT=120

# ---------- 出图（混元 HY-Image · TokenHub）----------
IMAGE_PROVIDER=hunyuan
# hy-image-v3.0 质量更好（异步约 15–30 秒）；hy-image-lite 更快但质量一般
IMAGE_MODEL=hy-image-v3.0
# IMAGE_API_KEY 可省略，默认复用 HUNYUAN_API_KEY
HUNYUAN_IMAGE_LITE_URL=https://tokenhub.tencentmaas.com/v1/api/image/lite
HUNYUAN_IMAGE_SUBMIT_URL=https://tokenhub.tencentmaas.com/v1/api/image/submit
HUNYUAN_IMAGE_QUERY_URL=https://tokenhub.tencentmaas.com/v1/api/image/query
HUNYUAN_IMAGE_RESOLUTION=1080:1920
HUNYUAN_IMAGE_POLL_INTERVAL=2
HUNYUAN_IMAGE_FALLBACK_LITE=true

# ---------- 开发降级（无 Key 时）----------
# LLM_PROVIDER=mock
# IMAGE_PROVIDER=mock

PORT=5070
